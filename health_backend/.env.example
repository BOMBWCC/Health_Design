# --- 数据库连接 ---
# 格式: postgresql://[用户名]:[密码]@[主机]:[端口]/[数据库名]
DB_URL=postgresql://postgres:yourpassword@db:5432/health_hub

# --- 安全与鉴权 ---
SECRET_KEY=yoursecretkeyforjwt-replace-this-in-vps
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=5256000  # 约 10 年 (永久有效)

# --- 初始管理员 ---
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASS=admin123
INITIAL_ADMIN_FULLNAME=Administrator

# 4. ETL & Aggregation
# Default statistical granularity: '1d', '12h', '1h'
DEFAULT_AGG_WINDOW=1d
# Default lookback window (days) for data correction
DEFAULT_LOOKBACK_DAYS=3
# Default execution interval (minutes)
DEFAULT_EXEC_INTERVAL_MINUTES=1440
# Initial data processing start point
AGGREGATION_START_TIME=2026-04-01T00:00:00Z
DISPLAY_TIMEZONE=Asia/Shanghai

